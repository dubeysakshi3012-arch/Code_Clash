FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# Ensure file change detection works reliably inside Docker on Windows/macOS
ENV WATCHPACK_POLLING=true
ENV WATCHPACK_POLLING_INTERVAL=1000

ENV NEXT_PUBLIC_API_URL=http://localhost:8000
ENV NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

EXPOSE 3000
CMD ["npm", "run", "dev"]
