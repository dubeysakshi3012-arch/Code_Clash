# Application
APP_NAME=CodeClash API
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/codeclash

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI (Optional - for AI-driven question generation)
OPENAI_API_KEY=

# Docker Judge (code execution)
# Linux/Mac: unix://var/run/docker.sock
# Windows (Docker Desktop): npipe:////./pipe/docker_engine
DOCKER_SOCKET_URL=unix://var/run/docker.sock
DOCKER_TIMEOUT_SECONDS=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
