# CodeClash Backend - Environment variables
# Copy to .env and fill in real values. Do not commit .env.

# Required
DATABASE_URL=postgresql://user:password@localhost:5432/codeclash
JWT_SECRET_KEY=your-secret-key-change-in-production

# Optional - Redis (defaults below)
REDIS_URL=redis://localhost:6379/0

# Optional - JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional - AI (OpenAI placeholder; Gemini used for match questions)
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
# Optional: Groq model (e.g. llama-3.3-70b-versatile, openai/gpt-oss-20b). Defaults to llama-3.3-70b-versatile.
GROQ_MODEL=

# Optional - Docker Judge
DOCKER_SOCKET_URL=unix://var/run/docker.sock
DOCKER_TIMEOUT_SECONDS=30

# Optional - Celery (defaults to REDIS_URL if empty)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TASK_TIME_LIMIT=600
CELERY_WORKER_CONCURRENCY=4

# Optional - CORS (JSON array or comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Optional - App
DEBUG=false

# Phase 3: Socket.io server URL and secret (for matchmaking)
SOCKET_SERVER_URL=http://localhost:3001
SOCKET_SERVER_SECRET=your-socket-server-secret-shared-with-socket-server
